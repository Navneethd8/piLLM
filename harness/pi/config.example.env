# Copy to ~/.pillm/.env on the Pi

PILLM_HOME=/home/navneeth/.pillm
PILLM_WORKSPACE=/home/navneeth/piLLM/harness

# Local inference (default)
PILLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Optional llama-server (when piLLM GGUF is deployed)
# LLAMA_SERVER_URL=http://127.0.0.1:8080/v1
# LLAMA_SERVER_MODEL=pillm-100m

# Cloud fallback (only when local health check fails or PILLM_FORCE_CLOUD=1)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Discord gateway (optional)
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_GUILD_IDS=
# DISCORD_ALLOWED_USER_IDS=

# Hermes-style threads: @mention once → bot creates a thread → chat freely in thread
DISCORD_AUTO_THREAD=1
# DISCORD_THREAD_REQUIRE_MENTION=1   # set to require @mention even inside threads
# DISCORD_NO_THREAD_CHANNELS=          # channel IDs that reply inline (no auto-thread)

# Web API
PILLM_WEB_HOST=0.0.0.0
PILLM_WEB_PORT=8787

# Agent limits (Pi 3B defaults)
PILLM_MAX_ITERATIONS=8
PILLM_MAX_TOKENS=256
PILLM_CONTEXT_TOKENS=2048

# Skills (procedural memory — opt-in, Pi-safe)
PILLM_SKILLS=1
PILLM_MAX_SKILLS=20
PILLM_MAX_SKILL_BYTES=4096

# Inference timeout (Pi 3B needs more than 120s — 10 min default)
PILLM_INFERENCE_TIMEOUT_MS=600000
