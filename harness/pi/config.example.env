# Copy to ~/.pillm/.env on the Pi

PILLM_HOME=/home/navneeth/.pillm
PILLM_WORKSPACE=/home/navneeth/piLLM/harness

# Provider routing (default: cloud-first when OPENAI_API_KEY or GEMINI_API_KEY is set, else local-first)
# cloud-first  — try cloud providers, fall back to local on rate limits / errors
# local-first  — try ollama first, cloud only if local is down
# openai       — OpenAI cloud only
# gemini       — Gemini cloud only
# ollama       — local only
PILLM_PROVIDER=local-first

# OpenAI cloud (first in cloud-first chain when key is set)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Google Gemini cloud (OpenAI-compatible endpoint; second in cloud-first when both keys set)
GEMINI_API_KEY=
# GOOGLE_API_KEY=                    # alias for GEMINI_API_KEY
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.0-flash

# Local inference
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Stand-in for future pillm-100m custom GGUF (~100-124M, not built yet)
OLLAMA_MODEL=smollm2:135m-instruct-q4_K_S
# Production fallback (494M, Pi 3B benchmark winner): OLLAMA_MODEL=qwen2.5:0.5b
# Dual-model routing (fast chat + tool-capable model):
# OLLAMA_CHAT_MODEL=smollm2:135m-instruct-q4_K_S
# OLLAMA_TOOL_MODEL=qwen2.5:0.5b
# PILLM_OLLAMA_DUAL=1
# Store Ollama models on USB thumb drive (set by pi/setup-ollama-usb.sh)
# OLLAMA_MODELS=/mnt/sda/ollama-models

# Future: custom piLLM GGUF via llama-server (placeholder — not built yet)
# LLAMA_SERVER_URL=http://127.0.0.1:8080/v1
# LLAMA_SERVER_MODEL=pillm-100m

# Legacy: PILLM_FORCE_CLOUD=1 forces cloud-only (same as PILLM_PROVIDER=openai)

# Discord gateway (optional)
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_GUILD_IDS=
# DISCORD_ALLOWED_USER_IDS=

# Hermes-style threads: @mention once → bot creates a thread → chat freely in thread
DISCORD_AUTO_THREAD=1
# DISCORD_THREAD_REQUIRE_MENTION=1   # set to require @mention even inside threads
# DISCORD_NO_THREAD_CHANNELS=          # channel IDs that reply inline (no auto-thread)

# Web API
PILLM_WEB_HOST=0.0.0.0
PILLM_WEB_PORT=8787

# Agent limits (Pi 3B defaults)
PILLM_MAX_ITERATIONS=8
PILLM_MAX_TOKENS=256
PILLM_CONTEXT_TOKENS=2048

# Skills (procedural memory — opt-in, Pi-safe)
PILLM_SKILLS=1
PILLM_MAX_SKILLS=20
PILLM_MAX_SKILL_BYTES=4096

# Inference timeout (Pi 3B needs more than 120s — 10 min default)
PILLM_INFERENCE_TIMEOUT_MS=600000

# Benchmark: first-load probe timeout (USB + 1GB RAM swap)
# PILLM_BENCHMARK_LOAD_PROBE_MS=900000
# PILLM_BENCHMARK_COOLDOWN_MS=5000
