[Unit]
Description=piLLM edge harness (web API + Discord gateway)
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@REPO@
Environment=PILLM_HOME=@HOME@/.pillm
Environment=PILLM_WORKSPACE=@REPO@
EnvironmentFile=-@HOME@/.pillm/.env
ExecStart=/usr/bin/node @REPO@/dist/cli.js gateway
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
